# Dependencies
node_modules/

# Build output
dist/
build/
*.tsbuildinfo

# Test / coverage
coverage/

# Local caches (disposable; rebuildable from IMAP + metadata API)
.cache/
*.eml
*.db
*.db-wal
*.db-shm
# The local message cache + draft store default to a `.sqlite` name (CACHE_DB_PATH, drafts.db) — ignore
# those + their WAL/shm sidecars so a backend boot / verify run never leaves untracked artifacts.
*.sqlite
*.sqlite-wal
*.sqlite-shm

# Secrets — NEVER commit (Golden rule #4). Per-mailbox {mailboxName}.env stays local.
.env
*.env
!.env.example

# Editor / OS
.DS_Store
*.local
.vite/
.idea/
.vscode/*
!.vscode/extensions.json
