# Mailordomo — example environment file.
# Copy to a per-mailbox file like `work.env` (gitignored) or use the macOS Keychain.
# NEVER commit real credentials (Golden rule #4). Email bodies never leave this machine.

# --- Metadata service (shared, token-auth) ---
METADATA_SERVICE_URL=http://localhost:8787
METADATA_PROJECT_ID=your-project-id
METADATA_PROJECT_TOKEN=your-shared-project-token

# --- Local app backend (bind to loopback only) ---
BACKEND_HOST=127.0.0.1
BACKEND_PORT=4317

# --- Mailbox: IMAP (read) + SMTP (manual send only) ---
# iCloud (@me.com) requires an app-specific password; Gmail needs OAuth2 or an app password.
IMAP_HOST=imap.mail.me.com
IMAP_PORT=993
IMAP_USER=you@me.com
IMAP_PASSWORD=app-specific-password
SMTP_HOST=smtp.mail.me.com
SMTP_PORT=587
SMTP_USER=you@me.com
SMTP_PASSWORD=app-specific-password

# --- Claude headless binary ---
# Mailordomo runs `claude` under your Claude SUBSCRIPTION (a shared rolling usage window), NOT
# pay-per-token API billing. Do NOT set ANTHROPIC_API_KEY: if it is set, `claude` bills the paid
# API instead of consuming your subscription — the app warns about this at startup.
CLAUDE_BIN=claude
# Usage THROTTLE (not a dollar budget): caps the background daemon's NOTIONAL Claude usage per
# rolling window so it doesn't exhaust the subscription window your interactive work shares.
# Units are notional (proxied by the binary's reported total_cost_usd). Tune to taste.
CLAUDE_USAGE_THROTTLE=2.50
CLAUDE_USAGE_WINDOW_HOURS=5
